{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure Debug",
      "type": "shell",
      "command": "cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "cmake --build build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Configure Debug",
      "problemMatcher": "$gcc",
      "group": "build"
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "ctest --test-dir build --output-on-failure",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Build",
      "problemMatcher": []
    }
  ]
}
